{
  "project_type": "microservice",
  "doc_hierarchy": {
    "layer1": "CLAUDE.md",
    "layer2": [
      "auto-submit-api/CLAUDE.md",
      "auto-submit-web/CLAUDE.md",
      "auto-submit-mgmt/CLAUDE.md",
      "auto-submit-client/CLAUDE.md",
      "ai-agent/CLAUDE.md",
      "ai-detection/CLAUDE.md",
      "syncdata/md/CLAUDE.md"
    ]
  },
  "doc_patterns": ["CLAUDE.md", "AGENTS.md"],
  "path_resolvers": [
    {"prefix": "memory/", "root": "$CLAUDE_MEMORY_DIR", "optional": true},
    {"prefix": "plans/",  "root": "$HOME/.claude/plans", "optional": true}
  ],
  "environment_domains": {
    "测试": {
      "ips": ["8.129.22.14"],
      "ports_prefix": "97",
      "namespace": "vs-bingo"
    },
    "生产": {
      "ips": ["47.112.120.194"],
      "ports_prefix": "98",
      "namespace": "vs-bingo-pro"
    },
    "本地": {
      "ips": ["127.0.0.1"],
      "ports_prefix": "98",
      "namespace": "vs-bingo-local"
    }
  },
  "staleness_threshold_days": 14,
  "ignore_paths": ["node_modules/", ".git/", "dist/", ".venv/", "__pycache__/", "target/"]
}
